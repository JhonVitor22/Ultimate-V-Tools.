{
  "name": "ultimate-v-tools",
  "version": "2.2.2",
  "description": "Ferramenta de Otimização e Licenciamento Extreme Edition",
  "main": "main.js",
  "author": "Jhon Vitor",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.vitor.ultimatevtools",
    "productName": "Ultimate V-tools",
    "win": {
      "target": "portable",
      "icon": "imagens/icon.ico"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/*",
      "!node_modules/*"
    ]
  },
  "devDependencies": {
    "electron": "^latest",
    "electron-builder": "^latest"
  }
}